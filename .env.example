# Токен бота (обязательно)
BOT_TOKEN=ваш_токен

# API ключ Google Gemini
GEMINI_API_KEY=ваш_ключ

# ID администраторов (через запятую)
ADMIN_IDS=123456789,987654321

# База данных и файл аккаунтов
DATABASE_URL=sqlite:///data/data.db
ACCOUNTS_FILE=data/accounts.json

# Настройки Google Sheets (опционально)
# Если указаны, бот будет записывать данные в таблицу
GOOGLE_CREDENTIALS_FILE=data/credentials.json   # путь к файлу ключа сервисного аккаунта
GOOGLE_SHEET_NAME=Comments                      # название таблицы в Google Sheets